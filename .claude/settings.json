{
  "_purpose": "PR review/merge enforcement layer. raw 머지/푸시 + raw review/comment 차단 → script 만 정직한 entry (safe-push/run.sh + post-review/post.sh). 다른 프로젝트 적용 시 본 file + .claude/hooks/ + .claude/skills/ + .github/ + .githooks/ copy.",
  "permissions": {
    "deny": [
      "Bash(gh pr merge:*)",
      "Bash(gh pr merge*)",
      "Bash(git push:*)",
      "Bash(git push*)",
      "Bash(gh api * --method PUT */merge*)",
      "Bash(gh api * -X PUT */merge*)",
      "Bash(gh api * --method POST */merges*)",
      "Bash(gh api * -X POST */merges*)",
      "Bash(git merge --ff-only origin/main*)",
      "Bash(git update-ref refs/heads/main*)",
      "Bash(git update-ref refs/heads/master*)",
      "Bash(gh pr review:*)",
      "Bash(gh pr review*)",
      "Bash(gh pr comment:*)",
      "Bash(gh pr comment*)"
    ],
    "ask": [
      "Edit(.claude/settings.json)",
      "Edit(.claude/hooks/**)",
      "Edit(.claude/skills/**)",
      "Edit(.githooks/**)",
      "Edit(.github/CODEOWNERS)",
      "Write(.claude/settings.json)",
      "Write(.claude/hooks/**)",
      "Write(.claude/skills/**)",
      "Write(.githooks/**)",
      "Write(.github/CODEOWNERS)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/pre-bash-gate.sh"
          }
        ]
      }
    ]
  }
}
