# macro-logbot 환경변수 — 실제 값은 .env (gitignore)

# --- 인증 (MVP — Open WebUI 와 backend 간 공유 단일 API key) ---
# Bearer 또는 X-API-Key 헤더에 동일 값 송신. 사외 PoC 한정 — 사내 운영은
# SSO/OAuth 통합 (FOLLOWUP task-SEC-002).
MACRO_LOGBOT_API_KEY=changeme-mvp-demo-key
# true 시 server key 미설정도 503. 기본은 dev 모드(false) — 미설정 허용 + WARN.
MACRO_LOGBOT_AUTH_REQUIRED=false

# --- LLM 모델 ---
# 사외 PoC 권장: gemini/gemini-1.5-flash (무료 한도 가장 넉넉).
MACRO_LOGBOT_DEFAULT_MODEL=openai/gpt-4o-mini

# 무료 LLM API keys (PoC용 — 4개 모두, 사용자가 발급)
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# 사내 LLM endpoint (운영용 — placeholder)
# MACRO_LOGBOT_LLM_BASE_URL=
# MACRO_LOGBOT_LLM_API_KEY=
