# macro-logbot 환경변수 — 실제 값은 .env (gitignore)

# --- 인증 (MVP — Open WebUI 와 backend 간 공유 단일 API key) ---
# Bearer 또는 X-API-Key 헤더에 동일 값 송신. 사외 PoC 한정 — 사내 운영은
# SSO/OAuth 통합 (FOLLOWUP task-SEC-002).
# 빈 값 또는 sentinel 그대로 두면 dev 모드 (AUTH_REQUIRED=false 시 인증 skip).
MACRO_LOGBOT_API_KEY=__SET_A_REAL_KEY__
# true 시 server key 미설정/sentinel 도 503. docker-compose 기본은 true (demo 안전).
MACRO_LOGBOT_AUTH_REQUIRED=true

# --- LLM 모델 ---
# Gemini 2.5 Flash-Lite — 1000 RPD free (Flash 의 50배). 답변 품질 약간 낮으나 PoC/개발 충분.
MACRO_LOGBOT_DEFAULT_MODEL=gemini/gemini-2.5-flash-lite

# 무료 LLM API keys (PoC용 — 4개 모두, 사용자가 발급)
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# 사내 LLM endpoint (운영용 — task-LG-002 구현 완료)
# 사내 LLM 통합 시 uncomment + 사내 endpoint 채우기:
# MACRO_LOGBOT_LLM_BASE_URL=https://<사내-llm-endpoint>
# MACRO_LOGBOT_LLM_API_KEY=<사내 API key>
# MACRO_LOGBOT_LLM_PROVIDER=openai  # 또는 anthropic / custom — LiteLLM custom_provider 형식

# --- 사내/사외 swap (image registry + PyPI mirror) ---
# 사외 PoC (default — 명시 불필요):
#   BASE_IMAGE=python:3.14-slim
#   PIP_INDEX_URL=https://pypi.org/simple
#   OPEN_WEBUI_IMAGE=ghcr.io/open-webui/open-webui:main

# 사내 운영 (uncomment 후 사내 mirror 경로 채우기):
# BASE_IMAGE=<internal-registry>/python:3.14-slim
# PIP_INDEX_URL=https://<internal-pypi>/simple
# OPEN_WEBUI_IMAGE=<internal-registry>/open-webui:main
